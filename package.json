{
  "name": "oneslice",
  "version": "0.1.0",
  "description": "Simple Electron app for slicing videos with ffmpeg.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win portable"
  },
  "keywords": [
    "electron",
    "ffmpeg",
    "video",
    "slice"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.6.4",
    "electron-reload": "^1.5.0"
  },
  "build": {
    "appId": "com.oneslice.app",
    "productName": "Oneslice",
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "files": [
      "src/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}